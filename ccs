#!/usr/bin/env zsh
# ccs — Claude Code Session Search
# 按关键词实时搜索 Claude Code 历史会话,fzf 选择后恢复会话。
# 架构:jsonl 数据源 → 增量抽取纯文本索引(每会话一个分片) → rg/fzf 实时搜索
set -euo pipefail

PROJECTS_DIR="${CCS_PROJECTS_DIR:-$HOME/.claude/projects}"
INDEX_DIR="${CCS_INDEX_DIR:-$HOME/.cache/ccs/index}"
SELF="${0:A}"

# ---------- jq 程序 ----------
# 公共部分:从一行 jsonl 记录提取纯对话文本,过滤噪声
# textof: content 可能是字符串(旧格式)或块数组(新格式,只取 text 块)
JQ_COMMON='
def textof:
  if type == "string" then .
  elif type == "array" then ([ .[] | select(type=="object" and .type=="text") | (.text // "") ] | join(" "))
  else "" end;
select(type == "object")
| select(.type == "user" or .type == "assistant")
| select((.isMeta // false) | not)
| (.message.content // "" | textof
   | gsub("</?command-(message|name|args)>"; " ")
   | gsub("^\\s+|\\s+$"; "")) as $t
| select(($t | gsub("\\s"; "") | length) > 0)
| select($t | test("^(<system-reminder|<local-command|Caveat: the messages below|\\[Request interrupted)") | not)
'

# 索引行:项目名 \t 日期 \t sessionId \t 角色 \t 文本(压平截断) \t cwd \t 源文件
JQ_INDEX="$JQ_COMMON"'
| [
    (if (.cwd // "") != "" then (.cwd | split("/") | last) else "?" end),
    ((.timestamp // "")[5:10]),
    $sid,
    (if .type == "user" then "🧑" else "🤖" end),
    ($t | gsub("[\\r\\n\\t]+"; " ") | .[0:500]),
    (.cwd // ""),
    $src
  ] | join("\t")'

# 预览:整个会话渲染为带颜色的对话轮次
JQ_PREVIEW="$JQ_COMMON"'
| (if .type == "user"
   then "\n[1;36m🧑 我[0m"
   else "\n[1;33m🤖 Claude[0m"
   end) + "\n" + $t'

# 复制用:同预览但纯文本、无 ANSI 颜色码
JQ_PREVIEW_PLAIN="$JQ_COMMON"'
| (if .type == "user" then "\n🧑 我" else "\n🤖 Claude" end) + "\n" + $t'

# ---------- 依赖检查 ----------
check_deps() {
  local dep missing=()
  for dep in fzf rg jq; do
    command -v "$dep" >/dev/null || missing+=("$dep")
  done
  if (( ${#missing} )); then
    print -u2 "ccs: 缺少依赖: ${missing[*]}"
    print -u2 "     brew install ${missing[*]}"
    exit 1
  fi
}

# ---------- 索引 ----------
# 单文件抽取(也供冒烟测试使用: ccs --extract <jsonl> [sid])
extract_file() {
  local jsonl="$1" sid="${2:-${1:t:r}}"
  jq -r --arg sid "$sid" --arg src "$jsonl" "$JQ_INDEX" "$jsonl"
}

# 增量更新:mtime 比对,只重建变化的分片;清理源文件已删除的分片
# 分片命名 <项目目录名>%<sessionId>.tsv ("%" 不会出现在转义后的目录名中)
update_index() {
  mkdir -p "$INDEX_DIR"
  local shard jsonl sid proj rebuilt=0 total=0

  for shard in "$INDEX_DIR"/*.tsv(N); do
    local base="${shard:t:r}"
    local pdir="${base%\%*}" s="${base##*\%}"
    [[ -f "$PROJECTS_DIR/$pdir/$s.jsonl" ]] || rm -f -- "$shard"
  done

  for jsonl in "$PROJECTS_DIR"/*/*.jsonl(N); do
    (( total += 1 ))
    sid="${jsonl:t:r}"
    proj="${jsonl:h:t}"
    shard="$INDEX_DIR/${proj}%${sid}.tsv"
    if [[ ! -f "$shard" || "$jsonl" -nt "$shard" ]]; then
      extract_file "$jsonl" "$sid" > "$shard" 2>/dev/null \
        || print -u2 "ccs: 解析异常,已跳过部分内容: ${jsonl:t}"
      touch -r "$jsonl" "$shard"   # 分片继承源文件 mtime,供按时间倒序排列
      (( rebuilt += 1 ))
    fi
  done
  (( rebuilt > 0 )) && print -u2 "ccs: 已索引 $rebuilt/$total 个会话"
  return 0
}

# ---------- 列表与搜索 ----------
# 全部索引行,按会话 mtime 倒序(zsh glob 限定符 om = 按修改时间降序)
cmd_list() {
  local -a shards=("$INDEX_DIR"/*.tsv(Nom))
  (( ${#shards} )) && cat -- "${shards[@]}"
  return 0
}

# 多关键词 AND 过滤:每个词一层 rg(固定字符串、忽略大小写),顺序保持时间倒序
_and_filter() {
  if (( $# == 0 )); then
    cat
  else
    local w="$1"; shift
    rg -iF -- "$w" | _and_filter "$@"
  fi
}

cmd_grep() {
  local q="${1:-}"
  cmd_list | _and_filter ${=q} || true
}

# ---------- 预览 ----------
cmd_preview() {
  local src="$1"; shift
  local q="${*:-}"
  [[ -f "$src" ]] || { print "源文件不存在: $src"; return 0; }
  jq -r "$JQ_PREVIEW" "$src" 2>/dev/null | {
    if [[ -n "$q" ]]; then
      local -a pats=()
      local w
      for w in ${=q}; do pats+=(-e "$w"); done
      rg --passthru --color=always -iF "${pats[@]}" || true
    else
      cat
    fi
  }
}

# 完整会话纯文本复制到剪贴板
cmd_copy() {
  local src="$1"
  [[ -f "$src" ]] || return 0
  jq -r "$JQ_PREVIEW_PLAIN" "$src" 2>/dev/null | pbcopy
}

# ---------- 主交互 ----------
main() {
  check_deps
  update_index

  local initial="${*:-}"
  local line
  line=$(
    fzf --disabled \
        --no-mouse \
        --ansi \
        --query="$initial" \
        --delimiter=$'\t' \
        --with-nth=1,2,4,5 \
        --tabstop=2 \
        --no-sort \
        --prompt='搜索会话> ' \
        --header='⏎ 恢复会话 │ ^O 全文 │ ^T 复制全文 │ ^Y 复制ID │ ^P 当前项目 │ ⇧↑↓ 滚动预览 │ 鼠标可直接框选复制' \
        --preview="$SELF --preview {7} {q}" \
        --preview-window='right:55%:wrap' \
        --bind="start:reload:$SELF --grep {q}" \
        --bind="change:reload:$SELF --grep {q}" \
        --bind="ctrl-o:execute:$SELF --preview {7} {q} | less -R" \
        --bind="ctrl-t:execute-silent:$SELF --copy {7}" \
        --bind="ctrl-y:execute-silent:printf %s {3} | pbcopy" \
        --bind="ctrl-p:transform-query(echo {q} ${PWD:t})+reload:$SELF --grep {q}"
  ) || exit 0

  local sid cwd
  sid="$(cut -f3 <<<"$line")"
  cwd="$(cut -f6 <<<"$line")"

  if [[ -n "$cwd" && -d "$cwd" ]]; then
    cd "$cwd"
    exec claude --resume "$sid"
  else
    print -u2 "ccs: 项目目录不存在: ${cwd:-未知}"
    print    "手动恢复: claude --resume $sid"
    exit 1
  fi
}

# ---------- 入口 ----------
case "${1:-}" in
  --grep)    shift; cmd_grep "${*:-}" ;;
  --preview) shift; cmd_preview "$@" ;;
  --copy)    shift; cmd_copy "$@" ;;
  --extract) shift; extract_file "$@" ;;
  --update)  check_deps; update_index ;;
  --rebuild) check_deps; rm -rf -- "$INDEX_DIR"; update_index; print "索引已全量重建" ;;
  -p)        shift; main "${PWD:t}" "$@" ;;
  -h|--help)
    cat <<'EOF'
ccs — Claude Code 会话搜索

用法:
  ccs [关键词...]   实时搜索全部会话(多个关键词为 AND 关系)
  ccs -p [关键词]   限定当前所在项目
  ccs --rebuild     强制全量重建索引

键位:
  ⏎        cd 到项目目录并恢复该会话 (claude --resume)
  Ctrl-O   全屏查看完整会话
  Ctrl-T   复制完整会话纯文本到剪贴板
  Ctrl-Y   复制 sessionId 到剪贴板
  Ctrl-P   把当前项目名加入搜索词
EOF
    ;;
  *) main "$@" ;;
esac
