#!/usr/bin/env zsh
# ccs — Claude Code Session Search
# 按关键词实时搜索 Claude Code 历史会话,fzf 选择后恢复会话。
# 架构:jsonl 数据源 → 增量抽取纯文本索引(每会话一个分片) → rg/fzf 实时搜索
set -euo pipefail

PROJECTS_DIR="${CCS_PROJECTS_DIR:-$HOME/.claude/projects}"
INDEX_DIR="${CCS_INDEX_DIR:-$HOME/.cache/ccs/index}"
SELF="${0:A}"

# ---------- jq 程序 ----------
# 公共部分:从一行 jsonl 记录提取纯对话文本,过滤噪声
# textof: content 可能是字符串(旧格式)或块数组(新格式,只取 text 块)
JQ_COMMON='
def textof:
  if type == "string" then .
  elif type == "array" then ([ .[] | select(type=="object" and .type=="text") | (.text // "") ] | join(" "))
  else "" end;
select(type == "object")
| select(.type == "user" or .type == "assistant")
| select((.isMeta // false) | not)
| (.message.content // "" | textof
   | gsub("</?command-(message|name|args)>"; " ")
   | gsub("^\\s+|\\s+$"; "")) as $t
| select(($t | gsub("\\s"; "") | length) > 0)
| select($t | test("^(<system-reminder|<local-command|<task-notification|Caveat: the messages below|\\[Request interrupted)") | not)
'

# 索引行(8 列):项目名 \t 日期 \t sessionId \t 角色 \t 全文(压平) \t cwd \t 源文件 \t 预览行号
# 用 foreach 跨消息累加行号:每条消息在预览中渲染为 空行+头行+文本行,
# 头行行号 = 之前所有消息的总行数 + 2,供 fzf --preview-window '+{8}' 直接跳转
# (与 jq -n 配合使用: inputs 流式读入)
# 项目名/恢复目录统一取会话最后一个非空 cwd($home):
# /cd 会让 Claude Code 把会话文件搬到新项目目录,恢复会话必须去最终 cwd;
# 且项目名逐条漂移会破坏列表的项目分组,故整个会话统一钉在 $home 上。
# 先 slurp 全部消息取 $home,再 foreach 累加预览行号输出
JQ_INDEX='
[inputs | '"$JQ_COMMON"' | {type, cwd: (.cwd // ""), ts: (.timestamp // ""), t: $t}] as $msgs
| ([$msgs[].cwd | select(. != "")] | last // "") as $home
| (if $home != "" then ($home | split("/") | last) else "?" end) as $proj
| foreach $msgs[] as $m
  ({total: 0, cur: 0};
   {cur: (.total + 2),
    total: (.total + 2 + ($m.t | split("\n") | length))};
   [
     $proj,
     ($m.ts[5:10]),
     $sid,
     (if $m.type == "user" then "🧑" else "🤖" end),
     ($m.t | gsub("[\\r\\n\\t]+"; " ")),
     $home,
     $src,
     (.cur | tostring)
   ] | join("\t"))'

# 预览:整个会话渲染为带颜色的对话轮次
JQ_PREVIEW="$JQ_COMMON"'
| (if .type == "user"
   then "\n[1;36m🧑 我[0m"
   else "\n[1;33m🤖 Claude[0m"
   end) + "\n" + $t'

# 复制用:同预览但纯文本、无 ANSI 颜色码
JQ_PREVIEW_PLAIN="$JQ_COMMON"'
| (if .type == "user" then "\n🧑 我" else "\n🤖 Claude" end) + "\n" + $t'

# ---------- 依赖检查 ----------
check_deps() {
  local dep missing=()
  for dep in fzf rg jq; do
    command -v "$dep" >/dev/null || missing+=("$dep")
  done
  if (( ${#missing} )); then
    print -u2 "ccs: 缺少依赖: ${missing[*]}"
    print -u2 "     brew install ${missing[*]}"
    exit 1
  fi
}

# ---------- 索引 ----------
# 单文件抽取(也供冒烟测试使用: ccs --extract <jsonl> [sid])
extract_file() {
  local jsonl="$1" sid="${2:-${1:t:r}}"
  jq -rn --arg sid "$sid" --arg src "$jsonl" "$JQ_INDEX" "$jsonl"
}

# 增量更新:mtime 比对,只重建变化的分片;清理源文件已删除的分片
# 分片命名 <项目目录名>%<sessionId>.tsv ("%" 不会出现在转义后的目录名中)
INDEX_FORMAT=5   # 索引格式/过滤规则版本,变化时递增,触发全量重建

update_index() {
  mkdir -p "$INDEX_DIR"
  local fmt_file="$INDEX_DIR/.format"
  if [[ ! -f "$fmt_file" || "$(<"$fmt_file")" != "$INDEX_FORMAT" ]]; then
    rm -rf -- "$INDEX_DIR"
    mkdir -p "$INDEX_DIR"
    print "$INDEX_FORMAT" > "$fmt_file"
  fi
  local shard jsonl sid proj rebuilt=0 total=0

  for shard in "$INDEX_DIR"/*.tsv(N); do
    local base="${shard:t:r}"
    local pdir="${base%\%*}" s="${base##*\%}"
    [[ -f "$PROJECTS_DIR/$pdir/$s.jsonl" ]] || rm -f -- "$shard"
  done

  for jsonl in "$PROJECTS_DIR"/*/*.jsonl(N); do
    (( total += 1 ))
    sid="${jsonl:t:r}"
    proj="${jsonl:h:t}"
    shard="$INDEX_DIR/${proj}%${sid}.tsv"
    if [[ ! -f "$shard" || "$jsonl" -nt "$shard" ]]; then
      extract_file "$jsonl" "$sid" > "$shard" 2>/dev/null \
        || print -u2 "ccs: 解析异常,已跳过部分内容: ${jsonl:t}"
      touch -r "$jsonl" "$shard"   # 分片继承源文件 mtime,供按时间倒序排列
      (( rebuilt += 1 ))
    fi
  done
  (( rebuilt > 0 )) && print -u2 "ccs: 已索引 $rebuilt/$total 个会话"
  return 0
}

# ---------- 列表与搜索 ----------
# 会话分割线:8 列结构,sessionId 列(第3列)为空作为分隔行标记,供 awk/回车识别
SEP_DIM=$'\e[2m'
SEP_RST=$'\e[0m'
SEP_LINE="${SEP_DIM}┄┄┄┄┄┄┄┄${SEP_RST}"$'\t\t\t\t'"${SEP_DIM}┄┄┄┄┄┄┄┄┄┄┄┄┄┄┄┄┄┄┄┄┄┄┄┄┄┄┄┄┄┄┄┄┄┄┄┄┄┄┄┄${SEP_RST}"$'\t\t\t1'

# 全部索引行,排序规则(fzf 列表自底向上增长,流中越靠前显示越靠底):
# 1. 项目分组不穿插,按项目最近活跃度排序,最新项目在流首(=屏幕最底,紧贴光标)
# 2. 项目内会话按 mtime 降序,最新会话靠底
# 3. 会话内消息倒序,最新消息靠底 —— 整个列表自底向上 = 由新到旧
# 4. 会话之间插入分割线
cmd_list() {
  local -a shards=("$INDEX_DIR"/*.tsv(Nom))
  (( ${#shards} )) || return 0

  # 分组键 = 分片首行的项目名(第 1 列,即 cwd basename)——这是用户看到的"项目"。
  # 不能用分片目录名:同一转义目录下不同子目录启动的会话,显示的项目名并不相同。
  # shards 已按 mtime 降序,项目首次出现的位置即该项目最新会话 → 得到项目活跃度顺序
  local -A contents=() proj_of=()
  local -A seen_proj=()
  local -a proj_order=() valid=()
  local s p content
  for s in "${shards[@]}"; do
    content="$(<"$s")"
    [[ -n "$content" ]] || continue
    p="${${content%%$'\n'*}%%$'\t'*}"
    contents[$s]="$content"
    proj_of[$s]="$p"
    valid+=("$s")
    [[ -n "${seen_proj[$p]:-}" ]] || { seen_proj[$p]=1; proj_order+=("$p"); }
  done

  local first=1
  local -a msg_lines
  for p in "${proj_order[@]}"; do
    for s in "${valid[@]}"; do
      [[ "${proj_of[$s]}" == "$p" ]] || continue
      (( first )) || print -r -- "$SEP_LINE"
      first=0
      msg_lines=("${(@f)contents[$s]}")
      print -rl -- "${(@Oa)msg_lines}"   # 倒序:会话内最新消息在前(=显示靠底)
    done
  done
}

# rg 粗筛链:每个词一层 rg 整行匹配(固定字符串、忽略大小写)。
# 整行匹配会连隐藏列一起算,可能放过假命中,但只作候选集收缩,精确性由 awk 保证
_rg_chain() {
  if (( $# == 1 )); then
    rg -iF -- "$1" || true
  else
    local w="$1"; shift
    { rg -iF -- "$w" || true } | _rg_chain "$@"
  fi
}

# 多关键词 AND 过滤 + 去重:rg 粗筛收缩候选集,awk 精筛保证语义
# - 只在可见列(项目/日期/角色/文本)内匹配,避免 sessionId/路径等隐藏列造成假命中
# - 相同 项目+角色+文本 的行只保留第一条(列表按时间倒序,即保留最新会话;
#   resume 会复制历史到新 sessionId 文件,同一消息会出现在多个会话中)
# - tolower 仅对 ASCII 生效,即英文忽略大小写,中文不受影响
cmd_grep() {
  local q="${1:-}"
  local -a words=(${=q})
  cmd_list \
  | { if (( ${#words} )); then _rg_chain "${words[@]}"; else cat; fi } \
  | awk -F'\t' -v q="$q" '
    BEGIN { n = split(tolower(q), ws, /[ \t]+/) }
    $3 == "" { if (n == 0) print; next }   # 分隔行:浏览时保留,搜索时丢弃,不去重
    {
      hay = tolower($1 FS $2 FS $4 FS $5)
      ok = 1
      for (i = 1; i <= n; i++)
        if (ws[i] != "" && index(hay, ws[i]) == 0) { ok = 0; break }
      if (!ok) next
      key = $1 FS $4 FS $5
      if (!seen[key]++) print
    }'
}

# ---------- 预览 ----------
cmd_preview() {
  local src="${1:-}"; (( $# )) && shift
  local q="${*:-}"
  [[ -n "$src" ]] || return 0   # 分隔行无源文件,预览留空
  [[ -f "$src" ]] || { print "源文件不存在: $src"; return 0; }
  jq -r "$JQ_PREVIEW" "$src" 2>/dev/null | {
    if [[ -n "$q" ]]; then
      local -a pats=()
      local w
      for w in ${=q}; do pats+=(-e "$w"); done
      rg --passthru --color=always \
         --colors=match:bg:yellow --colors=match:fg:black --colors=match:style:bold \
         -iF "${pats[@]}" || true
    else
      cat
    fi
  }
}

# 剪贴板抽象:自动适配 macOS(pbcopy)/ Wayland(wl-copy)/ X11(xclip/xsel)
clipcopy() {
  if command -v pbcopy >/dev/null; then pbcopy
  elif command -v wl-copy >/dev/null; then wl-copy
  elif command -v xclip >/dev/null; then xclip -selection clipboard
  elif command -v xsel >/dev/null; then xsel --clipboard --input
  else
    cat >/dev/null
    print -u2 "ccs: 未找到剪贴板工具(pbcopy/wl-copy/xclip/xsel)"
    return 1
  fi
}

# 完整会话纯文本复制到剪贴板
cmd_copy() {
  local src="${1:-}"
  [[ -f "$src" ]] || return 0
  jq -r "$JQ_PREVIEW_PLAIN" "$src" 2>/dev/null | clipcopy
}

# sessionId 复制到剪贴板
cmd_copy_id() {
  [[ -n "${1:-}" ]] || return 0
  printf %s "$1" | clipcopy
}

# ---------- 主交互 ----------
main() {
  check_deps
  update_index

  local initial="${*:-}"
  local line
  line=$(
    fzf --disabled \
        --ansi \
        --query="$initial" \
        --delimiter=$'\t' \
        --with-nth=1,2,4,5 \
        --tabstop=2 \
        --no-sort \
        --prompt='搜索会话> ' \
        --header='⏎ 恢复会话 │ ^O 全文 │ ^F 预览全屏 │ ^T 复制全文 │ ^Y 复制ID │ ^P 当前项目 │ Esc 退出' \
        --preview="$SELF --preview {7} {q}" \
        --preview-window='right:55%:wrap:+{8}' \
        --bind="start:reload:$SELF --grep {q}" \
        --bind="change:reload:$SELF --grep {q}" \
        --bind="ctrl-f:change-preview-window(up,90%,wrap,+{8}|right,55%,wrap,+{8})" \
        --bind="ctrl-o:execute:$SELF --preview {7} {q} | less -R" \
        --bind="ctrl-t:execute-silent:$SELF --copy {7}" \
        --bind="ctrl-y:execute-silent:$SELF --copy-id {3}" \
        --bind="ctrl-p:transform-query(echo {q} ${PWD:t})+reload:$SELF --grep {q}"
  ) || exit 0

  local sid cwd
  sid="$(cut -f3 <<<"$line")"
  cwd="$(cut -f6 <<<"$line")"
  [[ -z "$sid" ]] && exit 0   # 选中的是分隔行,静默退出

  if [[ -n "$cwd" && -d "$cwd" ]]; then
    cd "$cwd"
    exec claude --resume "$sid"
  else
    print -u2 "ccs: 项目目录不存在: ${cwd:-未知}"
    print    "手动恢复: claude --resume $sid"
    exit 1
  fi
}

# ---------- 入口 ----------
case "${1:-}" in
  --grep)    shift; cmd_grep "${*:-}" ;;
  --preview) shift; cmd_preview "$@" ;;
  --copy)    shift; cmd_copy "$@" ;;
  --copy-id) shift; cmd_copy_id "$@" ;;
  --extract) shift; extract_file "$@" ;;
  --update)  check_deps; update_index ;;
  --rebuild) check_deps; rm -rf -- "$INDEX_DIR"; update_index; print "索引已全量重建" ;;
  -p)        shift; main "${PWD:t}" "$@" ;;
  -h|--help)
    cat <<'EOF'
ccs — Claude Code 会话搜索

用法:
  ccs [关键词...]   实时搜索全部会话(多个关键词为 AND 关系)
  ccs -p [关键词]   限定当前所在项目
  ccs --rebuild     强制全量重建索引

键位:
  ⏎        cd 到项目目录并恢复该会话 (claude --resume)
  Ctrl-O   全屏查看完整会话
  Ctrl-F   预览窗口全屏/还原切换(方便鼠标选取预览文本)
  Ctrl-T   复制完整会话纯文本到剪贴板
  Ctrl-Y   复制 sessionId 到剪贴板
  Ctrl-P   把当前项目名加入搜索词
EOF
    ;;
  *) main "$@" ;;
esac
